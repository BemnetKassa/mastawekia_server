// This is your Prisma schema file,

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url is handled by prisma.config.ts
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  jobPosts  JobPost[]
}

enum Role {
  USER
  CLIENT
}

model JobPost {
  id          String   @id @default(cuid())
  title       String
  description String
  company     String
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
